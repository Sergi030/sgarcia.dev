---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchProjects, langColors } from '../data/github';
import { features } from '../config';

if (!features.projects) return Astro.redirect('/404');

const projects = await fetchProjects([
  { repo: 'Sergi030/vim-sisa-syntax', role: 'author' },
  { repo: 'Sergi030/dotfiles', role: 'author' },
  { repo: 'Sergi030/personal-webpage', role: 'author', nameOverride: 'sgarcia.dev', descOverride: 'This website. A personal blog built with Astro, Tailwind CSS 4, and deployed to GitHub Pages.' },
]);
---

<BaseLayout title="Projects" description="Open-source projects and contributions by Sergi Garcia Ibañez.">
  <section class="pt-4">
    <!-- Terminal header -->
    <div class="font-mono text-xs text-[var(--text-muted)] mb-6 animate-fade-up">
      <span class="text-[var(--accent)]">mehcachis@barcelona</span><span class="opacity-40">:</span><span class="text-[var(--text)]">~/projects</span><span class="opacity-40">$</span>
      <span class="ml-1">ls -la</span>
    </div>

    <h1 class="font-mono text-2xl sm:text-3xl font-bold text-[var(--text)] mb-2 tracking-tight animate-fade-up stagger-1">
      Projects
    </h1>
    <p class="font-mono text-sm text-[var(--text-muted)] mb-8 animate-fade-up stagger-1">
      total {projects.length}
    </p>

    <!-- Project cards -->
    <div class="space-y-3 animate-fade-up stagger-2">
      {projects.map((project, i) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'group block border border-[var(--border)] rounded-md bg-[var(--bg-alt)] p-5',
            'hover:border-[var(--accent)]/30 hover:bg-[var(--accent-dim)] transition-all duration-200',
            'animate-fade-up',
            `stagger-${Math.min(i + 3, 8)}`,
          ]}
        >
          <div class="flex items-start justify-between gap-4 mb-2">
            <div class="flex items-center gap-2">
              <span class="font-mono text-base font-semibold text-[var(--text)] group-hover:text-[var(--accent)] transition-colors">
                {project.name}
              </span>
              <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-[var(--tag-bg)] text-[var(--tag-text)] border border-[var(--accent)]/10">
                {project.role}
              </span>
            </div>
            <svg class="w-4 h-4 text-[var(--text-muted)] group-hover:text-[var(--accent)] transition-colors shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>

          <p class="text-sm text-[var(--text-muted)] mb-3 leading-relaxed">
            {project.description}
          </p>

          <!-- GitHub metadata -->
          <div class="flex items-center gap-4 font-mono text-[11px] text-[var(--text-muted)]">
            {project.language && (
              <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full" style={`background: ${langColors[project.language] || '#888'}`}></span>
                {project.language}
              </span>
            )}
            {project.stars > 0 && (
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
                {project.stars}
              </span>
            )}
            {project.updatedAt && (
              <span>
                updated {new Date(project.updatedAt).toLocaleDateString('en-CA')}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- Add more prompt -->
    <div class="mt-8 font-mono text-xs text-[var(--text-muted)] opacity-50 animate-fade-up stagger-6">
      <span class="text-[var(--accent)] opacity-60">#</span> more projects coming soon...
    </div>
  </section>
</BaseLayout>
